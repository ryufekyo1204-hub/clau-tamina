  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "dotenv": "^17.4.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "react": "^18.3.0",
